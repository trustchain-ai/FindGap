{
  "slug": "zhaoyaojing",
  "version": "0.3.0",
  "displayName": "照妖镜 Mirror Skill",
  "description": "在用户和 AI 协作的任何节点（评审 PRD / 评 PR / 审方案 / 看对话 / 看决策）识别 gap、推荐最优消除手段、多轮收敛到对齐。当用户说\"照一下\"\"有没有遗漏\"\"我没想到什么\"\"帮我看看这个对不对\"\"这方案靠谱吗\"\"检查盲点\"\"审一下\"或类似需要\"反向审视\"的场景时自动加载。",
  "triggerPhrases": [
    "/照妖镜",
    "照一下",
    "mirror",
    "审一下",
    "有没有遗漏",
    "靠谱吗",
    "我没想到什么",
    "检查盲点",
    "帮我看看这个对不对",
    "/zhaoyaojing-feedback",
    "/zhaoyaojing-rescan"
  ],
  "entrypoint": "skill/照妖镜.skill.md",
  "license": "MIT",
  "homepage": "https://github.com/290963249/zhaoyaojing",
  "minRuntime": {
    "claude-code": "2.1.145",
    "codex-cli": "0.40.0"
  },
  "compatibility": {
    "verified": [
      "Claude Code",
      "Hermes"
    ],
    "experimental": [
      "Cursor (Agent mode)",
      "Cline",
      "Continue",
      "Roo"
    ],
    "declared_only": [
      "Codex CLI",
      "OpenAI Responses API"
    ],
    "note": "只有 verified 列表是实测通过；其他需用户自行验证"
  },
  "gapTypes": {
    "G1-G8": "v0.1 基础逻辑层（主观锚词/隐含假设/角色心智漂移/未问的关键问题/来源缺失/反例缺失/不可证伪/责任真空）",
    "G9": "行业最佳实践 gap（8 子项：SLO/幂等/可观测性/灰度/弱网/限流/容量/对账）",
    "G10": "历史失败模式 gap（8 子项：CVE/postmortem/反模式/依赖隔离/迁移/供应链/备份/LLM 事故）",
    "G11": "跨域类比 gap（7 子项：金融对账/医疗 Checklist/Poka-Yoke/核电纵深/法律证据链/Pre-mortem/异常监测）",
    "G12": "监管合规 gap（10 子项：DSR/同意/跨境/保留期/泄露通知/未成年/PCI-DSS/自动化决策/审计/许可证）",
    "G13": "认知盲点 gap（8 子项：锚定/确认偏误/规划谬误/邓宁-克鲁格/乐观偏差/沉没成本/现状偏差/知识的诅咒）",
    "G14": "SMART 双向扫描（5 子项：S/M/A/R/T）"
  },
  "cognitiveLayers": [
    "known-unknown（已知的未知）",
    "unknown-unknown（未知的未知）",
    "known-flawed-preference（已知的偏好-带瑕疵）"
  ],
  "phases": [
    "Phase 1 Detect (识别)",
    "Phase 2 Decide (决策)",
    "Phase 3 Eliminate (消除)",
    "Phase 4 Converge (收敛，最多 3 轮)",
    "Output Contract (双轨报告)",
    "Feedback Hook (gap 唯一 ID)"
  ],
  "redlines": [
    "宁错杀不放过",
    "不依赖记忆抑制 gap",
    "禁止主观词输出",
    "不编造数字",
    "不超 3 轮"
  ],
  "doubleTrackTemplate": {
    "summary": "≤200字 / ≤12行 / emoji必现 / 必含下一步行",
    "detailed": "每条P0/P1含四件套（定位+三法命中+复查命令+误报申诉）"
  },
  "severityScheme": {
    "P0": {
      "emoji": "🔴",
      "sla": "24h",
      "gate": "阻合并+阻发版"
    },
    "P1": {
      "emoji": "🟡",
      "sla": "本迭代",
      "gate": "阻发版"
    },
    "P2": {
      "emoji": "🟢",
      "sla": "下迭代",
      "gate": "非阻断"
    },
    "P3": {
      "emoji": "⚪",
      "sla": "无",
      "gate": "非阻断"
    },
    "Drop": {
      "emoji": "🚫",
      "sla": "-",
      "gate": "关闭"
    }
  },
  "gapIdFormat": "G{family}-{idx}#{shortHash} | shortHash=sha1(location+evidence)[0:6]",
  "feedbackHook": {
    "command": "/zhaoyaojing-feedback <id> <accepted|rejected|known|fix-applied> [reason]",
    "rescan": "zhaoyaojing rescan <reportId>",
    "storage": "<artifact-root>/.zhaoyaojing/feedback.jsonl"
  },
  "selfCheckItems": [
    "C1 双轨齐全",
    "C2 严重度词表合规",
    "C3 精简版硬约束",
    "C4 详细版四件套",
    "C5 可复查性"
  ],
  "totalSubItems": "G1-G14 共 46 子项",
  "corePrinciple": "宁错杀不放过"
}